# Database
DATABASE_URL=postgresql+asyncpg://vernier:changeme@localhost:5432/vernier_news

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080    # 7 days
REFRESH_TOKEN_EXPIRE_MINUTES=43200   # 30 days

# App
APP_ENV=development
APP_DEBUG=false

# API connector keys (all optional — connectors are skipped if key is absent)
GUARDIAN_API_KEY=
GNEWS_API_KEY=
CURRENTS_API_KEY=
NYT_API_KEY=

# Admin API key — protects /api/v1/admin/* endpoints; used by the Telegram bot
# (and the legacy OpenClaw skills). Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# CORS allowed origins (comma-separated)
# Add http://localhost:PORT for local Flutter dev, e.g.:
#   CORS_ORIGINS=https://vernier.news,http://localhost:5173
CORS_ORIGINS=https://vernier.news

# Ollama (local LLM for categorisation)
# Docker on macOS: use http://host.docker.internal:11434
# VPS (Phase 3+): use http://ollama:11434 once Ollama is in docker-compose
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Postgres (for Docker Compose)
POSTGRES_USER=vernier
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vernier_news

# --- Telegram control bot (replaces OpenClaw) ---
# Enable the bot service. Docker Compose reads COMPOSE_PROFILES from this file;
# leave it commented out in local dev to keep the bot from starting.
# COMPOSE_PROFILES=bot
#
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram numeric user IDs allowed to use the bot
# (message @userinfobot to find yours). Empty = bot refuses to start (fail closed).
TELEGRAM_ALLOWED_USER_IDS=
# Chat that receives the daily digest + threshold alerts (your user ID, or a group ID).
# Leave empty to disable proactive alerting.
TELEGRAM_ALERT_CHAT_ID=
# Internal API base — Docker service name on the compose network
BOT_API_BASE_URL=http://api:8000
# Daily health digest hour (UTC, 0-23)
BOT_DIGEST_UTC_HOUR=8
# Threshold alerting
BOT_ALERT_POLL_MINUTES=15
BOT_QUEUE_DEPTH_THRESHOLD=100
BOT_INGEST_STALL_HOURS=3
