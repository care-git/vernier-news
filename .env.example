# Database
DATABASE_URL=postgresql+asyncpg://vernier:changeme@localhost:5432/vernier_news

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080    # 7 days
REFRESH_TOKEN_EXPIRE_MINUTES=43200   # 30 days

# App
APP_ENV=development
APP_DEBUG=false

# Postgres (for Docker Compose)
POSTGRES_USER=vernier
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vernier_news
